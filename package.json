{
  "name": "velance-app",
  "private": true,
  "version": "0.9.0-beta.4",
  "description": "Local-first desktop productivity analytics, focus tracking, and evidence-based coaching.",
  "author": "Velance <support@velance.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dr-Grimm/velance-app.git"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "node tests/smoke/run-smoke-tests.mjs",
    "test:smoke": "node tests/smoke/run-smoke-tests.mjs",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:build": "vite build && electron .",
    "rebuild:native": "electron-builder install-app-deps",
    "dist:win": "vite build && electron-builder --win && node -e \"require('fs').rmSync('release/app/win-unpacked',{recursive:true,force:true})\"",
    "dist:publish": "vite build && electron-builder --win --publish=always && node -e \"require('fs').rmSync('release/app/win-unpacked',{recursive:true,force:true})\""
  },
  "build": {
    "appId": "com.velance.app",
    "productName": "Velance",
    "npmRebuild": false,
    "afterPack": "./scripts/afterPack.cjs",
    "directories": {
      "output": "release/app"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/preload.cjs",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "Velance-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "Dr-Grimm",
      "repo": "velance-app",
      "releaseType": "release"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.0",
    "active-win": "^8.2.1",
    "apexcharts": "^5.6.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "electron-updater": "^6.6.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-vue-next": "^0.575.0",
    "pinia": "^3.0.4",
    "sql.js": "^1.14.1",
    "uiohook-napi": "^1.5.4",
    "vue": "^3.5.25",
    "vue-router": "^5.0.3",
    "vue3-apexcharts": "^1.10.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "rcedit": "^5.0.2",
    "sass": "^1.97.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
